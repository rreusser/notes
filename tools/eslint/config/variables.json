{
  "init-declarations": "off",
  "no-delete-var": "error",
  "no-label-var": "error",
  "no-restricted-globals": [
    "error",
    "event",
    "fdescribe"
  ],
  "no-shadow": "off",
  "no-shadow-restricted-names": "error",
  "no-undef": "error",
  "no-undef-init": "error",
  "no-undefined": "error",
  "no-unused-vars": [
    "error",
    {
      "vars": "all",
      "args": "after-used",
      "caughtErrors": "all"
    }
  ],
  "no-use-before-define": [
    "error",
    {
      "functions": false,
      "classes": true
    }
  ]
}
