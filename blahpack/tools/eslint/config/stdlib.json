{
  "stdlib/capitalized-comments": [
    "warn",
    {
      "whitelist": [
        "eslint",
        "eslint-enable",
        "eslint-enable-next-line",
        "eslint-disable",
        "eslint-disable-next-line",
        "returns",
        "e.g.,",
        "ndarray",
        "rehype",
        "remark",
        "stdlib",
        "throws"
      ]
    }
  ],
  "stdlib/doctest": "off",
  "stdlib/doctest-annotation-spacing": "error",
  "stdlib/doctest-marker": "error",
  "stdlib/doctest-quote-props": "error",
  "stdlib/empty-line-before-comment": "error",
  "stdlib/eol-open-bracket-spacing": "error",
  "stdlib/jsdoc-blockquote-indentation": [
    "error",
    2
  ],
  "stdlib/jsdoc-checkbox-character-style": [
    "error",
    {
      "checked": "x",
      "unchecked": " "
    }
  ],
  "stdlib/jsdoc-checkbox-content-indent": "error",
  "stdlib/jsdoc-code-block-style": [
    "error",
    "fenced"
  ],
  "stdlib/jsdoc-fenced-code-flag": [
    "error",
    {
      "allowEmpty": false
    }
  ],
  "stdlib/jsdoc-definition-case": "error",
  "stdlib/jsdoc-definition-spacing": "error",
  "stdlib/jsdoc-doctest": "error",
  "stdlib/jsdoc-doctest-decimal-point": "error",
  "stdlib/jsdoc-doctest-marker": "error",
  "stdlib/jsdoc-emphasis-marker": [
    "error",
    "_"
  ],
  "stdlib/jsdoc-empty-line-before-example": "error",
  "stdlib/jsdoc-example-require-spacing": "error",
  "stdlib/jsdoc-fenced-code-marker": [
    "error",
    "`"
  ],
  "stdlib/jsdoc-final-definition": "error",
  "stdlib/jsdoc-first-heading-level": [
    "error",
    2
  ],
  "stdlib/jsdoc-hard-break-spaces": "error",
  "stdlib/jsdoc-heading-increment": "warn",
  "stdlib/jsdoc-heading-style": [
    "error",
    "atx"
  ],
  "stdlib/jsdoc-leading-description-sentence": [
    "error",
    {
      "whitelist": [
        "ndarray",
        "rehype",
        "remark",
        "stdlib",
        "x-axis",
        "y-axis",
        "`x`",
        "`x`-value",
        "`y`",
        "`y`-value"
      ]
    }
  ],
  "stdlib/jsdoc-license-header-year": "off",
  "stdlib/jsdoc-linebreak-style": [
    "error",
    "unix"
  ],
  "stdlib/jsdoc-maximum-heading-length": [
    "error",
    80
  ],
  "stdlib/jsdoc-maximum-line-length": [
    "off"
  ],
  "stdlib/jsdoc-link-title-style": [
    "error",
    "\""
  ],
  "stdlib/jsdoc-list-item-bullet-indent": "error",
  "stdlib/jsdoc-list-item-content-indent": "error",
  "stdlib/jsdoc-list-item-indent": [
    "error",
    "tab-size"
  ],
  "stdlib/jsdoc-list-item-spacing": "error",
  "stdlib/jsdoc-markdown-remark": [
    "error",
    {
      "config": {
        "plugins": [
          null,
          [
            null,
            [
              "error"
            ]
          ]
        ]
      }
    }
  ],
  "stdlib/jsdoc-no-auto-link-without-protocol": "error",
  "stdlib/jsdoc-no-blockquote-without-marker": "error",
  "stdlib/jsdoc-no-consecutive-blank-lines": "off",
  "stdlib/jsdoc-no-duplicate-definitions": "error",
  "stdlib/jsdoc-no-duplicate-headings": "error",
  "stdlib/jsdoc-no-duplicate-headings-in-section": "error",
  "stdlib/jsdoc-no-duplicate-tags": "error",
  "stdlib/jsdoc-no-emphasis-as-heading": "error",
  "stdlib/jsdoc-no-empty-url": "error",
  "stdlib/jsdoc-no-heading-content-indent": "error",
  "stdlib/jsdoc-no-heading-indent": "error",
  "stdlib/jsdoc-no-heading-like-paragraph": "error",
  "stdlib/jsdoc-no-heading-punctuation": [
    "error",
    ".,;:!?"
  ],
  "stdlib/jsdoc-no-html": "error",
  "stdlib/jsdoc-no-inline-padding": "error",
  "stdlib/jsdoc-no-literal-urls": "error",
  "stdlib/jsdoc-no-missing-blank-lines": [
    "error",
    {
      "exceptTightLists": true
    }
  ],
  "stdlib/jsdoc-no-multiple-blank-lines": "error",
  "stdlib/jsdoc-no-multiple-toplevel-headings": "off",
  "stdlib/jsdoc-no-paragraph-content-indent": "error",
  "stdlib/jsdoc-no-reference-like-url": "error",
  "stdlib/jsdoc-no-shell-dollars": "off",
  "stdlib/jsdoc-no-shortcut-reference-image": "error",
  "stdlib/jsdoc-no-shortcut-reference-link": "error",
  "stdlib/jsdoc-no-space-aligned-asterisks": "error",
  "stdlib/jsdoc-no-table-indentation": "error",
  "stdlib/jsdoc-no-tabs": "error",
  "stdlib/jsdoc-no-undefined-references": "error",
  "stdlib/jsdoc-no-unused-definitions": "error",
  "stdlib/jsdoc-ordered-list-marker-style": [
    "error",
    "."
  ],
  "stdlib/jsdoc-ordered-list-marker-value": [
    "off",
    "ordered"
  ],
  "stdlib/jsdoc-private-annotation": "warn",
  "stdlib/jsdoc-require-throws-tags": "error",
  "stdlib/jsdoc-doctest-quote-props": "error",
  "stdlib/jsdoc-rule-style": [
    "error",
    "* * *"
  ],
  "stdlib/jsdoc-strong-marker": [
    "error",
    "*"
  ],
  "stdlib/jsdoc-table-cell-padding": [
    "error",
    "padded"
  ],
  "stdlib/jsdoc-table-pipe-alignment": "error",
  "stdlib/jsdoc-table-pipes": "error",
  "stdlib/jsdoc-tag-names": "error",
  "stdlib/jsdoc-tag-order": "error",
  "stdlib/jsdoc-tag-spacing": "error",
  "stdlib/jsdoc-typedef-typos": "error",
  "stdlib/jsdoc-unordered-list-marker-style": [
    "error",
    "-"
  ],
  "stdlib/jsdoc-main-export": "error",
  "stdlib/line-closing-bracket-spacing": "error",
  "stdlib/module-exports-last": "error",
  "stdlib/namespace-export-all": "warn",
  "stdlib/namespace-index-order": "error",
  "stdlib/new-cap-array": "error",
  "stdlib/new-cap-error": "error",
  "stdlib/new-cap-regexp": "error",
  "stdlib/no-dynamic-require": "error",
  "stdlib/no-empty-comments": "error",
  "stdlib/no-empty-lines-between-requires": "error",
  "stdlib/no-error-string-concat": "error",
  "stdlib/no-immediate-require": "error",
  "stdlib/no-internal-require": "error",
  "stdlib/no-multiple-empty-lines": "error",
  "stdlib/no-builtin-big-int": "error",
  "stdlib/no-builtin-math": "error",
  "stdlib/no-dynamic-exports": "error",
  "stdlib/no-nested-require": "error",
  "stdlib/no-unnecessary-nested-functions": "error",
  "stdlib/no-new-array": "error",
  "stdlib/no-redeclare": [
    "error",
    {
      "builtinGlobals": true,
      "globalsWhitelist": [
        "Array",
        "ArrayBuffer",
        "Boolean",
        "Buffer",
        "DataView",
        "Date",
        "Error",
        "EvalError",
        "Float32Array",
        "Float64Array",
        "Function",
        "Int8Array",
        "Int16Array",
        "Int32Array",
        "Map",
        "Number",
        "Object",
        "process",
        "Promise",
        "Proxy",
        "RangeError",
        "ReferenceError",
        "RegExp",
        "Set",
        "SharedArrayBuffer",
        "String",
        "Symbol",
        "SyntaxError",
        "TypeError",
        "Uint8Array",
        "Uint8ClampedArray",
        "Uint16Array",
        "Uint32Array",
        "URIError",
        "WebAssembly"
      ]
    }
  ],
  "stdlib/no-require-absolute-path": "error",
  "stdlib/no-require-index": "error",
  "stdlib/no-self-require": "error",
  "stdlib/no-unassigned-require": "error",
  "stdlib/repl-namespace-order": "off",
  "stdlib/require-file-extensions": [
    "error",
    {
      "extensionsWhitelist": [
        ".js",
        ".json",
        ".node"
      ]
    }
  ],
  "stdlib/require-globals": [
    "error",
    {
      "globals": [
        "ArrayBuffer",
        "BigInt",
        "BigInt64Array",
        "BigUint64Array",
        "Boolean",
        "Buffer",
        "DataView",
        "Float16Array",
        "Float32Array",
        "Float64Array",
        "Function",
        "Int8Array",
        "Int16Array",
        "Int32Array",
        "Number",
        "Object",
        "Promise",
        "process",
        "Proxy",
        "SharedArrayBuffer",
        "Symbol",
        "Uint8Array",
        "Uint8ClampedArray",
        "Uint16Array",
        "Uint32Array"
      ]
    }
  ],
  "stdlib/require-leading-slash": "error",
  "stdlib/require-spaces": "error",
  "stdlib/require-order": [
    "error",
    {
      "order": [
        "builtin",
        "external",
        "/^@stdlib/",
        "path"
      ]
    }
  ],
  "stdlib/section-headers": "error",
  "stdlib/first-unit-test": "error",
  "stdlib/ternary-condition-parentheses": "error",
  "stdlib/uppercase-required-constants": "error",
  "stdlib/section-header-empty-lines": "error",
  "stdlib/vars-order": [
    "error",
    {
      "order": "decreasing"
    }
  ]
}
