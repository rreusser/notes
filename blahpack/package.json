{
  "name": "blapack",
  "version": "1.0.0",
  "main": "generate.js",
  "type": "module",
  "scripts": {
    "test": "node --test 'lib/**/test/test*.js' 'lib/*.test.js' 2>&1 | awk '/ℹ (tests|suites|pass|fail|cancelled|skipped|todo|duration)/{buf=buf $0 ORS; next} {print} END{printf buf}'",
    "lint": "bash bin/lint.sh",
    "lint:fix": "bash bin/lint.sh --fix",
    "audit": "bash bin/audit.sh",
    "check": "npm test && npm run audit",
    "fixtures": "./test/generate_fixtures.sh",
    "report": "node bin/report.js > progress.html",
    "lint:learnings": "! grep -rl 'TODO: Fill in' lib/*/base/*/LEARNINGS.md 2>/dev/null | grep . && echo 'All LEARNINGS.md filled in' || (echo 'FAIL: Unfilled LEARNINGS.md found:' && grep -rl 'TODO: Fill in' lib/*/base/*/LEARNINGS.md && exit 1)",
    "bundle:notebook": "esbuild notebooks/aaa/laplace-entry.js --bundle --format=esm --outfile=notebooks/aaa/laplace-bundle.js --platform=neutral --main-fields=main,module",
    "bundle:naca": "esbuild notebooks/naca/naca-entry.js --bundle --format=esm --outfile=notebooks/naca/naca-bundle.js --platform=neutral --main-fields=main,module",
    "bundle:pseudospectra": "esbuild notebooks/pseudospectra/pspectra-entry.js --bundle --format=esm --outfile=notebooks/pseudospectra/pspectra-bundle.js --platform=neutral --main-fields=main,module",
    "dev": "npm run bundle:notebook && npm run bundle:naca && npm run bundle:pseudospectra && vite --port 5174"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@stdlib/stdlib": "^0.3.2",
    "escodegen": "^2.1.0",
    "esprima": "^4.0.1"
  },
  "devDependencies": {
    "@observablehq/notebook-kit": "^1.5.2",
    "@rreusser/mcp-observable-notebook-kit-debug": "^1.0.1",
    "doctrine": "^3.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^3.4.2"
  }
}
