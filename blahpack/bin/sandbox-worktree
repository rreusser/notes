#!/usr/bin/env bash
set -euo pipefail

# Spin up an isolated Claude sandbox in a git worktree.
#
# Usage:
#   bin/sandbox-worktree <name>          # create worktree + sandbox
#   bin/sandbox-worktree <name> --rm     # tear down both
#
# Creates:
#   ../blahpack-<name>/    (git worktree)
#   sandbox: blahpack-<name> (Docker sandbox)
#
# Prerequisites:
#   - Docker Desktop 4.58+
#   - blahpack-sandbox:latest image (run `bin/sandbox --build` first)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
IMAGE="blahpack-sandbox:latest"

if [[ $# -lt 1 ]]; then
    echo "Usage: bin/sandbox-worktree <name> [--rm]" >&2
    echo "" >&2
    echo "Active worktree sandboxes:" >&2
    docker sandbox ls 2>/dev/null | grep "blahpack-" || echo "  (none)" >&2
    exit 1
fi

NAME="$1"
SANDBOX_NAME="blahpack-${NAME}"
WORKTREE_DIR="$(dirname "$ROOT_DIR")/blahpack-${NAME}"

# Teardown mode
if [[ "${2:-}" == "--rm" ]]; then
    echo "Removing sandbox '$SANDBOX_NAME'..." >&2
    docker sandbox rm "$SANDBOX_NAME" 2>/dev/null || true
    echo "Removing worktree '$WORKTREE_DIR'..." >&2
    git -C "$ROOT_DIR" worktree remove "$WORKTREE_DIR" 2>/dev/null || true
    echo "Done." >&2
    exit 0
fi

# Build image if it doesn't exist yet
if ! docker image inspect "$IMAGE" &>/dev/null; then
    echo "Building sandbox template (first run)..." >&2
    docker build -t "$IMAGE" -f "$ROOT_DIR/Dockerfile.sandbox" "$ROOT_DIR"
fi

# Create worktree if it doesn't exist
if [[ ! -d "$WORKTREE_DIR" ]]; then
    echo "Creating worktree at $WORKTREE_DIR..." >&2
    git -C "$ROOT_DIR" worktree add "$WORKTREE_DIR" HEAD --detach
    # Install node_modules in the worktree
    echo "Installing dependencies..." >&2
    (cd "$WORKTREE_DIR" && npm install --silent)
fi

# Launch or resume sandbox
if docker sandbox ls 2>/dev/null | grep -q "$SANDBOX_NAME"; then
    echo "Resuming sandbox '$SANDBOX_NAME'..." >&2
    exec docker sandbox run "$SANDBOX_NAME"
else
    echo "Creating sandbox '$SANDBOX_NAME'..." >&2
    exec docker sandbox run \
        --name "$SANDBOX_NAME" \
        -t "$IMAGE" \
        claude \
        "$WORKTREE_DIR" \
        "${STDLIB_PATH:-$HOME/gh/stdlib-js/stdlib}":ro
fi
